          "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
          },
          "expr": "sum by (instance, job) (rate(redis_cache_hits_total[5m])) / (sum by (instance, job) (rate(redis_cache_hits_total[5m])) + sum by (instance, job) (rate(redis_cache_misses_total[5m])))",
