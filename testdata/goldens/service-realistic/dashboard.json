      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
          },
          "expr": "sum by (instance, job) (rate(redis_cache_hits_total[5m]))",
          "legendFormat": "{{instance}} {{job}} hits",
          "refId": "A"
